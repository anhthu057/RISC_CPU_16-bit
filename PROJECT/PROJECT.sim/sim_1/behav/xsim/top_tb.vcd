$var wire 1 !! MemtoReg $end
$var wire 16 $! read_data [15:0] $end
$var wire 16 %! ALU_result [15:0] $end
$var wire 16 '! out [15:0] $end
$upscope $end
$upscope $end
$upscope $end
$upscope $end
$enddefinitions $end

