$var reg 2 B" w_spec_regs_out [1:0] $end
$var reg 16 C" read_data_out [15:0] $end
$var reg 16 D" alu_result_out [15:0] $end
$var reg 3 E" write_reg_addr_out [2:0] $end
$upscope $end
$scope module wb_stage $end
$var wire 1 !! memToReg_in $end
